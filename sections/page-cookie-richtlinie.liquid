{{ 'section-main-page.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="page-width page-width--narrow section-{{ section.id }}-padding">
  <h1 class="main-page-title page-title h0">Cookie-Richtlinie</h1>
  <div class="rte">
    <h2>Was sind Cookies?</h2>
    <p>Cookies sind kleine Textdateien, die auf Ihrem Endgerät gespeichert werden.</p>

    <h2>Cookie-Kategorien</h2>

    <h3>1. Essenzielle Cookies (erforderlich)</h3>
    <ul>
      <li>Warenkorb-Cookie</li>
      <li>Sitzungs-Cookie</li>
      <li>CSRF-Token (Sicherheit)</li>
      <li>Consent-Cookie</li>
    </ul>
    <p><em>Diese Cookies können nicht deaktiviert werden.</em></p>

    <h3>2. Funktionale Cookies</h3>
    <p>Spracheinstellungen, Währung, Merklisten.</p>

    <h3>3. Analyse/Statistik Cookies</h3>
    <p>[BITTE EINTRAGEN: z.B. Google Analytics, Shopify Analytics]</p>

    <h3>4. Marketing Cookies</h3>
    <p>[BITTE EINTRAGEN: z.B. Facebook Pixel]</p>

    <h2>Verwaltung und Opt-out</h2>
    <p>Sie können Ihre Cookie-Einstellungen jederzeit über unseren Cookie-Banner oder den Footer-Link anpassen.</p>

    <h2>Kontakt</h2>
    <p>E-Mail: <a href="mailto:bytinytales@web.de">bytinytales@web.de</a></p>

    <hr>
    <p><small>Stand: Februar 2026 | bytinytes</small></p>
  </div>
</div>

{% schema %}
{
  "name": "Seite: Cookie-Richtlinie",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand oben",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 36
    }
  ]
}
{% endschema %}

{{ 'section-premium-retouren.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="premium-retouren section-{{ section.id }}-padding color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    
    {%- if section.settings.heading != blank -%}
      <div class="premium-retouren__header">
        <h1 class="premium-retouren__title">{{ section.settings.heading | escape }}</h1>
        <p class="premium-retouren__subtitle">Hier finden Sie alle Informationen zu Retouren und Umtausch bei bytinytales.</p>
      </div>
    {%- endif -%}

    <div class="premium-retouren__grid">
      
      {%- comment -%}Left: Info{%- endcomment -%}
      <div class="premium-retouren__info">
        
        <div class="premium-retouren__info-block">
          <h2 class="premium-retouren__info-title">Retouren-Richtlinie</h2>
          <ul class="premium-retouren__info-list">
            <li><span class="premium-retouren__info-check">✓</span> 30 Tage Rückgaberecht</li>
            <li><span class="premium-retouren__info-check">✓</span> Kostenlose Rücksendung</li>
            <li><span class="premium-retouren__info-check">✓</span> Schnelle Erstattung</li>
            <li><span class="premium-retouren__info-check">✓</span> Umtausch möglich</li>
          </ul>
        </div>

        <div class="premium-retouren__info-block">
          <h2 class="premium-retouren__info-title">So funktioniert's</h2>
          <div class="premium-retouren__steps">
            <div class="premium-retouren__step">
              <span class="premium-retouren__step-number">1</span>
              <div class="premium-retouren__step-content">
                <h3>Retoure anmelden</h3>
                <p>Kontaktieren Sie uns per E-Mail oder Telefon</p>
              </div>
            </div>
            <div class="premium-retouren__step">
              <span class="premium-retouren__step-number">2</span>
              <div class="premium-retouren__step-content">
                <h3>Artikel zurücksenden</h3>
                <p>Verpacken Sie die Ware sicher und senden Sie sie zurück</p>
              </div>
            </div>
            <div class="premium-retouren__step">
              <span class="premium-retouren__step-number">3</span>
              <div class="premium-retouren__step-content">
                <h3>Erstattung erhalten</h3>
                <p>Nach Prüfung erfolgt die Rückzahlung innerhalb 5-7 Werktagen</p>
              </div>
            </div>
          </div>
        </div>

        <div class="premium-retouren__info-block">
          <h2 class="premium-retouren__info-title">Kontakt für Retouren</h2>
          <div class="premium-retouren__info-item">
            <svg class="premium-retouren__info-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            <a href="mailto:bytinytales@web.de" class="premium-retouren__info-link">bytinytales@web.de</a>
          </div>
          <div class="premium-retouren__info-item">
            <svg class="premium-retouren__info-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <span>+49 170 731 0173</span>
          </div>
        </div>

        <div class="premium-retouren__hint">
          <svg class="premium-retouren__hint-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="16" x2="12" y2="12"/>
            <line x1="12" y1="8" x2="12.01" y2="8"/>
          </svg>
          <span>Bei Fragen zur Retoure erreichen Sie uns Mo–Fr, 9–17 Uhr.</span>
        </div>

      </div>

      {%- comment -%}Right: FAQ Accordion{%- endcomment -%}
      <div class="premium-retouren__faq-wrapper">
        <h2 class="premium-retouren__faq-title">Häufige Fragen</h2>
        
        <div class="premium-retouren__faq-list">
          
          <details class="premium-retouren__faq-item">
            <summary class="premium-retouren__faq-question">
              <span>Wie lange habe ich Zeit für eine Rücksendung?</span>
              <svg class="premium-retouren__faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6,9 12,15 18,9"/>
              </svg>
            </summary>
            <div class="premium-retouren__faq-answer">
              <p>Sie haben 30 Tage ab Erhalt der Ware Zeit, um Artikel zurückzusenden. Die Frist beginnt am Tag der Lieferung.</p>
            </div>
          </details>

          <details class="premium-retouren__faq-item">
            <summary class="premium-retouren__faq-question">
              <span>Wer trägt die Rücksendekosten?</span>
              <svg class="premium-retouren__faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6,9 12,15 18,9"/>
              </svg>
            </summary>
            <div class="premium-retouren__faq-answer">
              <p>Die Rücksendung ist für Sie kostenlos. Wir stellen Ihnen ein kostenloses Rücksende-Label zur Verfügung.</p>
            </div>
          </details>

          <details class="premium-retouren__faq-item">
            <summary class="premium-retouren__faq-question">
              <span>Wie erhalte ich mein Geld zurück?</span>
              <svg class="premium-retouren__faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6,9 12,15 18,9"/>
              </svg>
            </summary>
            <div class="premium-retouren__faq-answer">
              <p>Die Erstattung erfolgt auf das ursprüngliche Zahlungsmittel innerhalb von 5-7 Werktagen nach Eingang der Rücksendung.</p>
            </div>
          </details>

          <details class="premium-retouren__faq-item">
            <summary class="premium-retouren__faq-question">
              <span>Kann ich Artikel umtauschen?</span>
              <svg class="premium-retouren__faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6,9 12,15 18,9"/>
              </svg>
            </summary>
            <div class="premium-retouren__faq-answer">
              <p>Ja, Umtausch ist möglich. Bitte geben Sie bei der Retourenanmeldung an, welche Größe oder Farbe Sie wünschen.</p>
            </div>
          </details>

          <details class="premium-retouren__faq-item">
            <summary class="premium-retouren__faq-question">
              <span>Muss die Ware original verpackt sein?</span>
              <svg class="premium-retouren__faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6,9 12,15 18,9"/>
              </svg>
            </summary>
            <div class="premium-retouren__faq-answer">
              <p>Die Ware muss ungetragen und in einwandfreiem Zustand sein. Bitte nutzen Sie nach Möglichkeit die Originalverpackung.</p>
            </div>
          </details>

        </div>

        <a href="/pages/kontakt" class="premium-retouren__cta">
          <span>Retoure anmelden</span>
          <svg class="premium-retouren__cta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12,5 19,12 12,19"/>
          </svg>
        </a>

      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Retouren & Umtausch",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Retouren & Umtausch",
      "label": "Überschrift"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Retouren & Umtausch"
    }
  ]
}
{% endschema %}

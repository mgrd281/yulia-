{%- comment -%}
  Premium Announcement Bar - Calm, minimal, hides on scroll
{%- endcomment -%}

{%- style -%}
  .premium-announcement {
    --announcement-bg: {{ section.settings.background_color | default: '#1a1a1a' }};
    --announcement-text: {{ section.settings.text_color | default: '#ffffff' }};
    --announcement-height: 38px;
    
    position: relative;
    width: 100%;
    height: var(--announcement-height);
    background: var(--announcement-bg);
    color: var(--announcement-text);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    line-height: var(--announcement-height);
    overflow: hidden;
    z-index: 100;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), height 0.3s;
    will-change: transform, height;
  }
  
  .premium-announcement.is-hidden {
    transform: translateY(-100%);
    height: 0;
  }
  
  .premium-announcement__container {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    padding: 0 1rem;
  }
  
  .premium-announcement__text {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  
  .premium-announcement__link {
    color: inherit;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    transition: opacity 0.2s;
  }
  
  .premium-announcement__link:hover {
    opacity: 0.8;
  }
  
  .premium-announcement__link svg {
    width: 14px;
    height: 14px;
  }
  
  @media screen and (max-width: 749px) {
    .premium-announcement {
      --announcement-height: 34px;
      font-size: 0.7rem;
    }
  }
{%- endstyle -%}

<div
  class="premium-announcement"
  id="PremiumAnnouncement"
  data-hide-on-scroll="{{ section.settings.hide_on_scroll | default: true }}"
>
  <div class="premium-announcement__container page-width">
    {%- if section.blocks.size > 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.settings.text != blank -%}
          <div class="premium-announcement__text" {{ block.shopify_attributes }}>
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" class="premium-announcement__link">
                <span>{{ block.settings.text | escape }}</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            {%- else -%}
              <span>{{ block.settings.text | escape }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    {%- else -%}
      <div class="premium-announcement__text">
        <span>Willkommen bei bytinytales · Versand aus Deutschland</span>
      </div>
    {%- endif -%}
  </div>
</div>

{%- if section.settings.hide_on_scroll -%}
  <script>
    (function() {
      const announcement = document.getElementById('PremiumAnnouncement');
      if (!announcement) return;
      
      let lastScrollY = window.scrollY;
      let ticking = false;
      
      function updateAnnouncement() {
        const currentScrollY = window.scrollY;
        
        if (currentScrollY > lastScrollY && currentScrollY > 100) {
          announcement.classList.add('is-hidden');
        } else if (currentScrollY < lastScrollY) {
          announcement.classList.remove('is-hidden');
        }
        
        lastScrollY = currentScrollY;
        ticking = false;
      }
      
      window.addEventListener('scroll', function() {
        if (!ticking) {
          requestAnimationFrame(updateAnnouncement);
          ticking = true;
        }
      }, { passive: true });
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Premium Announcement Bar",
  "max_blocks": 3,
  "class": "premium-announcement-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "hide_on_scroll",
      "label": "Hide on scroll down",
      "default": true,
      "info": "Premium behavior: hides when scrolling down, shows when scrolling up"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Willkommen bei bytinytales · Versand aus Deutschland",
          "label": "Text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Announcement Bar",
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "text": "Willkommen bei bytinytales · Versand aus Deutschland"
          }
        }
      ]
    }
  ]
}
{% endschema %}

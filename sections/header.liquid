{%- comment -%}
  Premium Header - AboutYou-level Navigation
  Modern, app-like header with consistent SVG icon system
{%- endcomment -%}

{{ 'section-premium-header.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #PremiumHeader {
    --header-height: {{ section.settings.padding_top | plus: section.settings.padding_bottom | plus: 24 }}px;
  }
{%- endstyle -%}

<div class="premium-header-wrapper" id="PremiumHeaderWrapper">
  <header class="premium-header page-width" id="PremiumHeader">
    
    {%- comment -%}Mobile Menu Button{%- endcomment -%}
    <button 
      type="button" 
      class="premium-header__icon-btn premium-header__menu-btn" 
      aria-label="{{ 'accessibility.menu' | t }}"
      aria-expanded="false"
      aria-controls="PremiumDrawer"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>

    {%- comment -%}Logo{%- endcomment -%}
    <div class="premium-header__logo">
      <a href="{{ routes.root_url }}" class="premium-header__logo-link">
        {%- if settings.logo != blank -%}
          <img 
            src="{{ settings.logo | image_url: width: 200 }}" 
            alt="{{ shop.name | escape }}"
            class="premium-header__logo-img"
            width="{{ settings.logo_width }}"
            height="auto"
          >
        {%- else -%}
          <span class="premium-header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    {%- comment -%}Desktop Navigation{%- endcomment -%}
    {%- if section.settings.menu != blank -%}
      <nav class="premium-header__nav" role="navigation" aria-label="Main">
        <ul class="premium-header__menu">
          {%- for link in linklists[section.settings.menu].links -%}
            <li class="premium-header__menu-item">
              <a 
                href="{{ link.url }}" 
                class="premium-header__menu-link{% if link.active %} is-active{% endif %}"
                {% if link.active %}aria-current="page"{% endif %}
              >
                {{ link.title | escape }}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </nav>
    {%- endif -%}

    {%- comment -%}Icons{%- endcomment -%}
    <div class="premium-header__icons">
      
      {%- comment -%}Search{%- endcomment -%}
      <button 
        type="button" 
        class="premium-header__icon-btn premium-header__search-btn"
        aria-label="{{ 'general.search.search' | t }}"
        aria-expanded="false"
        aria-controls="PremiumSearchOverlay"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>

      {%- comment -%}Account{%- endcomment -%}
      {%- if shop.customer_accounts_enabled -%}
        <a 
          href="{{ routes.account_url }}" 
          class="premium-header__icon-btn"
          aria-label="{{ 'customer.account.title' | t }}"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </a>
      {%- endif -%}

      {%- comment -%}Cart{%- endcomment -%}
      <a 
        href="{{ routes.cart_url }}" 
        class="premium-header__icon-btn"
        id="cart-icon-bubble"
        aria-label="{{ 'templates.cart.cart' | t }}"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 6h15l-1.5 9h-12L6 6z"/>
          <circle cx="9" cy="20" r="1.5"/>
          <circle cx="18" cy="20" r="1.5"/>
          <path d="M6 6L5 3H2"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="premium-header__cart-badge">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>
  </header>
</div>

{%- comment -%}Search Overlay{%- endcomment -%}
<div class="premium-search-overlay" id="PremiumSearchOverlay" role="dialog" aria-modal="true" aria-label="{{ 'general.search.search' | t }}">
  <div class="premium-search-overlay__container">
    <form action="{{ routes.search_url }}" method="get" role="search" class="premium-search-overlay__input-wrapper">
      <svg class="premium-search-overlay__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/>
        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input 
        type="search" 
        name="q" 
        class="premium-search-overlay__input" 
        placeholder="{{ 'general.search.search' | t }}..."
        aria-label="{{ 'general.search.search' | t }}"
        autocomplete="off"
      >
      <button type="button" class="premium-search-overlay__close" aria-label="{{ 'accessibility.close' | t }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </form>
    <div class="premium-search-overlay__results" id="SearchResults"></div>
  </div>
</div>

{%- comment -%}Mobile Drawer{%- endcomment -%}
<div class="premium-drawer-overlay" id="PremiumDrawerOverlay"></div>
<aside class="premium-drawer" id="PremiumDrawer" role="dialog" aria-modal="true" aria-label="{{ 'accessibility.menu' | t }}">
  <div class="premium-drawer__header">
    <div class="premium-drawer__header-icons">
      {%- comment -%}Search in drawer{%- endcomment -%}
      <button type="button" class="premium-header__icon-btn premium-drawer__search-btn" aria-label="{{ 'general.search.search' | t }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>
      
      {%- comment -%}Account in drawer{%- endcomment -%}
      {%- if shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}" class="premium-header__icon-btn" aria-label="{{ 'customer.account.title' | t }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </a>
      {%- endif -%}
      
      {%- comment -%}Cart in drawer{%- endcomment -%}
      <a href="{{ routes.cart_url }}" class="premium-header__icon-btn" aria-label="{{ 'templates.cart.cart' | t }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 6h15l-1.5 9h-12L6 6z"/>
          <circle cx="9" cy="20" r="1.5"/>
          <circle cx="18" cy="20" r="1.5"/>
          <path d="M6 6L5 3H2"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="premium-header__cart-badge">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>
    
    <button type="button" class="premium-drawer__close" aria-label="{{ 'accessibility.close' | t }}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>
  
  {%- if section.settings.menu != blank -%}
    <nav class="premium-drawer__nav" role="navigation" aria-label="Mobile menu">
      <ul class="premium-drawer__menu">
        {%- for link in linklists[section.settings.menu].links -%}
          <li class="premium-drawer__menu-item">
            <a 
              href="{{ link.url }}" 
              class="premium-drawer__menu-link{% if link.active %} is-active{% endif %}"
              {% if link.active %}aria-current="page"{% endif %}
            >
              {{ link.title | escape }}
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </nav>
  {%- endif -%}
</aside>

{%- comment -%}Header JavaScript{%- endcomment -%}
<script>
  (function() {
    const header = document.getElementById('PremiumHeaderWrapper');
    const menuBtn = header.querySelector('.premium-header__menu-btn');
    const searchBtn = header.querySelector('.premium-header__search-btn');
    const drawer = document.getElementById('PremiumDrawer');
    const drawerOverlay = document.getElementById('PremiumDrawerOverlay');
    const drawerClose = drawer.querySelector('.premium-drawer__close');
    const searchOverlay = document.getElementById('PremiumSearchOverlay');
    const searchClose = searchOverlay.querySelector('.premium-search-overlay__close');
    const searchInput = searchOverlay.querySelector('.premium-search-overlay__input');
    
    let lastScrollY = window.scrollY;
    let ticking = false;
    
    // Hide header on scroll down
    function updateHeader() {
      const currentScrollY = window.scrollY;
      
      if (currentScrollY > lastScrollY && currentScrollY > 100) {
        header.classList.add('is-hidden');
      } else if (currentScrollY < lastScrollY) {
        header.classList.remove('is-hidden');
      }
      
      lastScrollY = currentScrollY;
      ticking = false;
    }
    
    window.addEventListener('scroll', function() {
      if (!ticking) {
        requestAnimationFrame(updateHeader);
        ticking = true;
      }
    }, { passive: true });
    
    // Drawer toggle
    function openDrawer() {
      drawer.classList.add('is-open');
      drawerOverlay.classList.add('is-open');
      menuBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      drawerClose.focus();
    }
    
    function closeDrawer() {
      drawer.classList.remove('is-open');
      drawerOverlay.classList.remove('is-open');
      menuBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      menuBtn.focus();
    }
    
    menuBtn.addEventListener('click', openDrawer);
    drawerClose.addEventListener('click', closeDrawer);
    drawerOverlay.addEventListener('click', closeDrawer);
    
    // Search overlay toggle
    function openSearch() {
      searchOverlay.classList.add('is-open');
      searchBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      setTimeout(() => searchInput.focus(), 100);
    }
    
    function closeSearch() {
      searchOverlay.classList.remove('is-open');
      searchBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
    
    searchBtn.addEventListener('click', openSearch);
    searchClose.addEventListener('click', closeSearch);
    searchOverlay.addEventListener('click', function(e) {
      if (e.target === searchOverlay) closeSearch();
    });
    
    // Keyboard accessibility
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        if (drawer.classList.contains('is-open')) closeDrawer();
        if (searchOverlay.classList.contains('is-open')) closeSearch();
      }
    });
    
    // Drawer search button
    const drawerSearchBtn = drawer.querySelector('.premium-drawer__search-btn');
    if (drawerSearchBtn) {
      drawerSearchBtn.addEventListener('click', function() {
        closeDrawer();
        setTimeout(openSearch, 300);
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Premium Header",
  "class": "section-header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Menu"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 24,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 24,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 12
    }
  ]
}
{% endschema %}

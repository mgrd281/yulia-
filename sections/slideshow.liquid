{%- comment -%}
  Premium Hero Slideshow - AboutYou-level UI
  Modern, app-like experience with overlay text system
{%- endcomment -%}

{{ 'section-premium-hero.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #PremiumHero-{{ section.id }} {
    --hero-height-desktop: {{ section.settings.height_desktop | default: 70 }}vh;
    --hero-height-mobile: {{ section.settings.height_mobile | default: 85 }}vh;
    --hero-overlay-top: rgba(0,0,0,{{ section.settings.overlay_top | divided_by: 100.0 }});
    --hero-overlay-bottom: rgba(0,0,0,{{ section.settings.overlay_bottom | divided_by: 100.0 }});
    --hero-text-align: {{ section.settings.text_alignment | default: 'left' }};
  }
{%- endstyle -%}

<premium-hero
  id="PremiumHero-{{ section.id }}"
  class="premium-hero{% if section.settings.layout == 'grid' %} page-width{% endif %}"
  role="region"
  aria-roledescription="{{ 'sections.slideshow.carousel' | t }}"
  aria-label="{{ section.settings.accessibility_info | escape }}"
  data-autoplay="{{ section.settings.auto_rotate | default: false }}"
  data-speed="{{ section.settings.change_slides_speed | times: 1000 }}"
  data-total="{{ section.blocks.size }}"
>
  {%- if section.blocks.size > 1 -%}
    <nav class="premium-hero__nav" aria-label="Slide navigation">
      <button
        type="button"
        class="premium-hero__arrow premium-hero__arrow--prev"
        aria-label="{{ 'sections.slideshow.previous_slideshow' | t }}"
        aria-controls="HeroSlider-{{ section.id }}"
      >
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button
        type="button"
        class="premium-hero__arrow premium-hero__arrow--next"
        aria-label="{{ 'sections.slideshow.next_slideshow' | t }}"
        aria-controls="HeroSlider-{{ section.id }}"
      >
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </nav>
  {%- endif -%}

  <div
    id="HeroSlider-{{ section.id }}"
    class="premium-hero__slider"
    aria-live="polite"
    aria-atomic="true"
  >
    {%- for block in section.blocks -%}
      {%- liquid
        assign height = block.settings.image.width | divided_by: block.settings.image.aspect_ratio | round
        assign sizes = '100vw'
        assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
        assign fetch_priority = 'auto'
        if section.index == 1 and forloop.first
          assign fetch_priority = 'high'
        endif
      -%}
      <div
        class="premium-hero__slide{% if forloop.first %} is-active{% endif %}"
        id="HeroSlide-{{ section.id }}-{{ forloop.index }}"
        {{ block.shopify_attributes }}
        role="group"
        aria-roledescription="{{ 'sections.slideshow.slide' | t }}"
        aria-label="{{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
        data-index="{{ forloop.index0 }}"
      >
        {%- comment -%}Background Image{%- endcomment -%}
        <div class="premium-hero__media">
          {%- if block.settings.image -%}
            {%- if forloop.first -%}
              {{
                block.settings.image
                | image_url: width: 3840
                | image_tag:
                  height: height,
                  sizes: sizes,
                  widths: widths,
                  fetchpriority: fetch_priority,
                  class: 'premium-hero__image',
                  alt: block.settings.image.alt | default: block.settings.heading
              }}
            {%- else -%}
              {{
                block.settings.image
                | image_url: width: 3840
                | image_tag:
                  loading: 'lazy',
                  height: height,
                  sizes: sizes,
                  widths: widths,
                  class: 'premium-hero__image',
                  alt: block.settings.image.alt | default: block.settings.heading
              }}
            {%- endif -%}
          {%- else -%}
            {{ 'hero-apparel-1' | placeholder_svg_tag: 'premium-hero__placeholder' }}
          {%- endif -%}
          <div class="premium-hero__overlay"></div>
        </div>

        {%- comment -%}Content Overlay{%- endcomment -%}
        <div class="premium-hero__content-wrapper page-width">
          <div class="premium-hero__content premium-hero__content--{{ section.settings.text_alignment | default: 'left' }}">
            {%- if block.settings.subheading != blank -%}
              <span class="premium-hero__eyebrow">{{ block.settings.subheading | escape }}</span>
            {%- endif -%}
            
            {%- if block.settings.heading != blank -%}
              <h2 class="premium-hero__heading{% if section.settings.heading_size != blank %}{{ section.settings.heading_size }}{% else %} premium-hero__heading--large{% endif %}">
                {{ block.settings.heading }}
              </h2>
            {%- endif -%}
            
            {%- if block.settings.description != blank -%}
              <p class="premium-hero__description">{{ block.settings.description | escape }}</p>
            {%- endif -%}
            
            {%- if block.settings.button_label != blank -%}
              <a
                href="{{ block.settings.link | default: '#' }}"
                class="premium-hero__cta"
                aria-label="{{ block.settings.button_label | escape }}"
              >
                <span class="premium-hero__cta-text">{{ block.settings.button_label | escape }}</span>
                <span class="premium-hero__cta-icon">
                  <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <div class="premium-hero__dots" role="tablist" aria-label="Slide indicators">
      {%- for block in section.blocks -%}
        <button
          type="button"
          class="premium-hero__dot{% if forloop.first %} is-active{% endif %}"
          data-slide="{{ forloop.index0 }}"
          aria-label="Gehe zu Slide {{ forloop.index }}"
          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          role="tab"
        ></button>
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- comment -%}Lightweight slider JS{%- endcomment -%}
  <script>
    (function() {
      const hero = document.getElementById('PremiumHero-{{ section.id }}');
      if (!hero) return;

      const slider = hero.querySelector('.premium-hero__slider');
      const slides = hero.querySelectorAll('.premium-hero__slide');
      const dots = hero.querySelectorAll('.premium-hero__dot');
      const prevBtn = hero.querySelector('.premium-hero__arrow--prev');
      const nextBtn = hero.querySelector('.premium-hero__arrow--next');
      
      const autoplay = hero.dataset.autoplay === 'true';
      const speed = parseInt(hero.dataset.speed) || 5000;
      const total = slides.length;
      
      let currentIndex = 0;
      let autoplayTimer = null;
      let touchStartX = 0;
      let touchEndX = 0;

      function showSlide(index) {
        if (index < 0) index = total - 1;
        if (index >= total) index = 0;
        
        slides.forEach((slide, i) => {
          slide.classList.toggle('is-active', i === index);
          slide.setAttribute('aria-hidden', i !== index ? 'true' : 'false');
        });
        
        dots.forEach((dot, i) => {
          dot.classList.toggle('is-active', i === index);
          dot.setAttribute('aria-selected', i === index ? 'true' : 'false');
        });
        
        currentIndex = index;
      }

      function nextSlide() {
        showSlide(currentIndex + 1);
      }

      function prevSlide() {
        showSlide(currentIndex - 1);
      }

      function startAutoplay() {
        if (autoplay) {
          autoplayTimer = setInterval(nextSlide, speed);
        }
      }

      function stopAutoplay() {
        if (autoplayTimer) {
          clearInterval(autoplayTimer);
        }
      }

      if (prevBtn) {
        prevBtn.addEventListener('click', () => {
          stopAutoplay();
          prevSlide();
          startAutoplay();
        });
      }

      if (nextBtn) {
        nextBtn.addEventListener('click', () => {
          stopAutoplay();
          nextSlide();
          startAutoplay();
        });
      }

      dots.forEach((dot, i) => {
        dot.addEventListener('click', () => {
          stopAutoplay();
          showSlide(i);
          startAutoplay();
        });
      });

      // Swipe support
      slider.addEventListener('touchstart', (e) => {
        touchStartX = e.changedTouches[0].screenX;
        stopAutoplay();
      }, { passive: true });

      slider.addEventListener('touchend', (e) => {
        touchEndX = e.changedTouches[0].screenX;
        const diff = touchStartX - touchEndX;
        
        if (Math.abs(diff) > 50) {
          if (diff > 0) nextSlide();
          else prevSlide();
        }
        startAutoplay();
      }, { passive: true });

      // Keyboard navigation
      hero.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') {
          stopAutoplay();
          prevSlide();
          startAutoplay();
        } else if (e.key === 'ArrowRight') {
          stopAutoplay();
          nextSlide();
          startAutoplay();
        }
      });

      // Pause on hover
      hero.addEventListener('mouseenter', stopAutoplay);
      hero.addEventListener('mouseleave', startAutoplay);

      // Initialize
      slides.forEach((slide, i) => {
        slide.setAttribute('aria-hidden', i !== 0 ? 'true' : 'false');
      });
      
      startAutoplay();
    })();
  </script>
</premium-hero>

{% schema %}
{
  "name": "Premium Hero Slideshow",
  "tag": "section",
  "class": "section section--full-width",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "options": [
        {
          "value": "full_bleed",
          "label": "Full width"
        },
        {
          "value": "grid",
          "label": "Grid width"
        }
      ],
      "default": "full_bleed",
      "label": "Layout"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Height (desktop)",
      "default": 70
    },
    {
      "type": "range",
      "id": "height_mobile",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Height (mobile)",
      "default": 85
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left",
      "label": "Text alignment"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "premium-hero__heading--small",
          "label": "Small"
        },
        {
          "value": "premium-hero__heading--medium",
          "label": "Medium"
        },
        {
          "value": "premium-hero__heading--large",
          "label": "Large"
        }
      ],
      "default": "premium-hero__heading--large",
      "label": "Heading size"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "range",
      "id": "overlay_top",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Overlay darkness (top)",
      "default": 30
    },
    {
      "type": "range",
      "id": "overlay_bottom",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Overlay darkness (bottom)",
      "default": 10
    },
    {
      "type": "header",
      "content": "Slideshow"
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto-rotate slides",
      "default": false
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Change slides every",
      "default": 5
    },
    {
      "type": "header",
      "content": "Accessibility"
    },
    {
      "type": "text",
      "id": "accessibility_info",
      "label": "Accessibility label",
      "default": "Slideshow about our products and collections"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Eyebrow / Category",
          "default": "New Collection",
          "info": "Small text above the main heading"
        },
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading",
          "default": "Premium Lifestyle Essentials"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "info": "Optional short description"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Jetzt entdecken"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Hero Slideshow",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "subheading": "Uhren & Lifestyle",
            "heading": "Entdecke einzigartige Momente",
            "button_label": "Jetzt shoppen",
            "description": "Premium Uhren, LEGO Sets & mehr"
          }
        },
        {
          "type": "slide",
          "settings": {
            "subheading": "Neu eingetroffen",
            "heading": "Limited Editions",
            "button_label": "Entdecken",
            "description": "Exklusive Stücke für Sammler"
          }
        }
      ]
    }
  ]
}
{% endschema %}
